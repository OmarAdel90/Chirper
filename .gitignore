# -------------------------------
# Laravel Standard Ignores
# -------------------------------

# Composer dependencies
/vendor/
composer.phar
composer.lock

# Node dependencies (if using Laravel Mix, Vite, or npm)
/node_modules/
npm-debug.log
npm-error.log
yarn-error.log
package-lock.json
yarn.lock

# Compiled assets
/public/css/
/public/js/
/public/mix-manifest.json
/public/build/
/public/hot
/public/hot-update.json
public/storage/

# Environment files
.env
.env.backup
.env.production
.env.local
.env.*.local

# IDE and editor files
/.idea/
/.vscode/
*.swp
*.swo
*~
.DS_Store
*.sublime-*
.editorconfig
.netbeans
.project
.classpath

# Laravel specific
/storage/*.key
/storage/framework/cache/
/storage/framework/sessions/
/storage/framework/testing/
/storage/framework/views/
/storage/logs/
/bootstrap/cache/
storage/clockwork/

# Testing
/.phpunit.result.cache
/.phpunit.cache
/phpunit.xml
/coverage/
/test-reports/
/.phpstan.cache/
/.psalm/
.phpunit.result.cache

# Debugging
/.debug/
/.log/
*.log
/.phpdebugbar/

# Cache files
/.cache/
.php_cs.cache
.php-cs-fixer.cache

# Package manager lock files (optional - commit or ignore based on team preference)
# composer.lock  # Uncomment if you want to ignore but generally SHOULD commit in apps

# Laravel Sail (Docker)
/.sail/
docker-compose.override.yml

# Laravel Telescope
/storage/telescope/

# Laravel Horizon
/storage/horizon/

# Laravel Pulse
/storage/pulse/

# Temporary files
/tmp/
temp/
*.tmp
*.temp

# OS generated files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Backup files
*.bak
*.old
*.orig
*.sql
*.sql.gz
*.zip
*.tar
*.tar.gz

# Security
/.env
.env.*.local
/.env.local
/.env.*.php
/auth.json
/.auth.json
/.github/

# Build outputs
/build/
/dist/
*.phar

# Documentation
/docs/_build/
/docs/api/

# Laravel Spark
/storage/spark/

# Laravel Nova
/nova/

# Sentry
/.sentryclirc

